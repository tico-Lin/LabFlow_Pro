{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Allow the main window to select and import local experimental data files.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**/*" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**/*" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**/*" }
      ]
    }
  ]
}
